package com.finsync.finance.model;

import jakarta.persistence.*;

@Entity
@Table(name = "bank_accounts")
public class BankAccount {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private String accountNumber;
    private String bankName;
    private double balance;

    @ManyToOne
    @JoinColumn(name = "user_id")
    private AppUser user;

    public BankAccount() {}

    public BankAccount(String accountNumber, String bankName, double balance, AppUser appUser) {
        this.accountNumber = accountNumber;
        this.bankName = bankName;
        this.balance = balance;
        this.user = appUser;
    }

    public Long getId() { return id; }
    public String getAccountNumber() { return accountNumber; }
    public String getBankName() { return bankName; }
    public double getBalance() { return balance; }
    public AppUser getAppUser() { return user; }

    public void setId(Long id) { this.id = id; }
    public void setAccountNumber(String accountNumber) { this.accountNumber = accountNumber; }
    public void setBankName(String bankName) { this.bankName = bankName; }
    public void setBalance(double balance) { this.balance = balance; }
    public void setAppUser(AppUser appUser) { this.user = appUser; }
}
